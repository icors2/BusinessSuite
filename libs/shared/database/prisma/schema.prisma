generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  orgId        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  roles        UserRole[]
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]     @relation("AuditActor")
  employee     Employee?
}

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  users     UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  timestamp  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([timestamp])
}

model Product {
  id                String              @id @default(uuid())
  sku               String              @unique
  description       String
  unitOfMeasure     String
  category          String?
  listPrice         Decimal?            @db.Decimal(18, 2)
  mpsStrategy       MpsStrategy?
  procurementType   ProcurementType       @default(BUY)
  preferredVendorId String?
  leadTimeDays      Int                   @default(0)
  active            Boolean               @default(true)
  deletedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  documents         Document[]
  inventory         InventoryQuantity[]
  movements         InventoryMovement[]
  quoteLines        QuoteLine[]
  salesOrderLines   SalesOrderLine[]
  workOrders        WorkOrder[]
  bom               BillOfMaterials?
  bomComponents     BomLine[]             @relation("BomComponent")
  requisitions      PurchaseRequisition[]
  purchaseOrderLines PurchaseOrderLine[]
  asnLines          AsnLine[]
  preferredVendor   Vendor?               @relation("ProductPreferredVendor", fields: [preferredVendorId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([category])
  @@index([preferredVendorId])
}

// ---------------------------------------------------------------------------
// Phase 5 — WMS (Inventory)
//
// Locations and bins hold per-product quantities. Movements are append-only;
// on-hand and allocated are updated transactionally. available = onHand - allocated.
// ---------------------------------------------------------------------------

enum MovementType {
  RECEIPT
  PUTAWAY
  PICK
  SHIP
  ADJUST
  ALLOCATE
  DEALLOCATE
}

model Location {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  type      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bins Bin[]

  @@index([active])
}

model Bin {
  id          String   @id @default(uuid())
  locationId  String
  code        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location           Location            @relation(fields: [locationId], references: [id])
  inventory          InventoryQuantity[]
  movementsAt        InventoryMovement[] @relation("MovementBin")
  movementsFrom      InventoryMovement[] @relation("MovementFromBin")
  movementsTo        InventoryMovement[] @relation("MovementToBin")

  @@index([locationId])
  @@index([active])
}

model InventoryQuantity {
  id        String   @id @default(uuid())
  productId String
  binId     String
  onHand    Decimal  @default(0) @db.Decimal(18, 4)
  allocated Decimal  @default(0) @db.Decimal(18, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  bin     Bin     @relation(fields: [binId], references: [id])

  @@unique([productId, binId])
  @@index([productId])
  @@index([binId])
}

model InventoryMovement {
  id          String       @id @default(uuid())
  type        MovementType
  productId   String
  binId       String?
  fromBinId   String?
  toBinId     String?
  quantity    Decimal      @db.Decimal(18, 4)
  reasonCode  String?
  note        String?
  createdById String?
  createdAt   DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  bin     Bin?    @relation("MovementBin", fields: [binId], references: [id], onDelete: SetNull)
  fromBin Bin?    @relation("MovementFromBin", fields: [fromBinId], references: [id], onDelete: SetNull)
  toBin   Bin?    @relation("MovementToBin", fields: [toBinId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Phase 4 — PLM & Documents
//
// Engineering documents linked to Products. Revisions are immutable — uploads
// create new revision rows; prior revisions are never deleted.
// ---------------------------------------------------------------------------

enum DocumentStatus {
  DRAFT
  IN_REVIEW
  RELEASED
  OBSOLETE
}

model Document {
  id                  String             @id @default(uuid())
  productId           String
  name                String
  docType             String?
  currentRevisionId   String?            @unique
  releasedRevisionId  String?            @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  product          Product             @relation(fields: [productId], references: [id])
  revisions        DocumentRevision[]
  currentRevision  DocumentRevision?   @relation("DocumentCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  releasedRevision DocumentRevision?   @relation("DocumentReleasedRevision", fields: [releasedRevisionId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([name])
}

model DocumentRevision {
  id             String         @id @default(uuid())
  documentId     String
  revisionNumber Int
  status         DocumentStatus @default(DRAFT)
  fileName       String
  mimeType       String
  sizeBytes      Int
  objectKey      String         @unique
  notes          String?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  document              Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  currentForDocument    Document? @relation("DocumentCurrentRevision")
  releasedForDocument   Document? @relation("DocumentReleasedRevision")

  @@unique([documentId, revisionNumber])
  @@index([documentId])
  @@index([status])
}

model Customer {
  id              String    @id @default(uuid())
  name            String
  email           String?
  phone           String?
  billingAddress  Json?
  shippingAddress Json?
  creditTerms     String?
  priceTier       String?
  active          Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  invoices        Invoice[]
  quotes          Quote[]
  salesOrders     SalesOrder[]

  @@index([active])
  @@index([name])
}

model Vendor {
  id                String                @id @default(uuid())
  name              String
  email             String?
  phone             String?
  address           Json?
  paymentTerms      String?
  leadTimeDays      Int                   @default(0)
  active            Boolean               @default(true)
  deletedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  bills             Bill[]
  preferredProducts Product[]             @relation("ProductPreferredVendor")
  requisitions      PurchaseRequisition[]
  purchaseOrders    PurchaseOrder[]

  @@index([active])
  @@index([name])
}

// ---------------------------------------------------------------------------
// Phase 3 — Finance & Accounting Core
//
// Double-entry ledger is the financial source of truth. Invoices, bills, and
// payments auto-post balanced journal entries. Posted entries are immutable;
// corrections use reversing entries.
// ---------------------------------------------------------------------------

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum BillStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum PaymentType {
  INVOICE
  BILL
}

model Account {
  id        String      @id @default(uuid())
  code      String      @unique
  name      String
  type      AccountType
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  journalLines JournalLine[]
  billLines    BillLine[]

  @@index([type])
  @@index([active])
}

model JournalEntry {
  id            String        @id @default(uuid())
  entryNumber   String        @unique
  date          DateTime
  memo          String?
  status        JournalStatus @default(DRAFT)
  postedAt      DateTime?
  reversalOfId  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         JournalLine[]
  reversalOf    JournalEntry?  @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversals     JournalEntry[] @relation("JournalReversal")
  invoice       Invoice?
  bill          Bill?
  payment       Payment?

  @@index([status])
  @@index([date])
}

model JournalLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @default(0) @db.Decimal(18, 2)
  credit         Decimal  @default(0) @db.Decimal(18, 2)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  customerId      String
  issueDate       DateTime
  dueDate         DateTime
  status          InvoiceStatus @default(DRAFT)
  total           Decimal       @db.Decimal(18, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(18, 2)
  journalEntryId  String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  lines        InvoiceLine[]
  payments     Payment[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 2)
  amount      Decimal @db.Decimal(18, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Bill {
  id             String     @id @default(uuid())
  billNumber     String     @unique
  vendorId       String
  issueDate      DateTime
  dueDate        DateTime
  status         BillStatus @default(DRAFT)
  total          Decimal    @db.Decimal(18, 2)
  amountPaid     Decimal    @default(0) @db.Decimal(18, 2)
  journalEntryId String?    @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  vendor       Vendor        @relation(fields: [vendorId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  lines        BillLine[]
  payments     Payment[]

  @@index([vendorId])
  @@index([status])
  @@index([dueDate])
}

model BillLine {
  id               String  @id @default(uuid())
  billId           String
  description      String
  quantity         Decimal @db.Decimal(18, 4)
  unitPrice        Decimal @db.Decimal(18, 2)
  amount           Decimal @db.Decimal(18, 2)
  expenseAccountId String

  bill           Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  expenseAccount Account @relation(fields: [expenseAccountId], references: [id])

  @@index([billId])
  @@index([expenseAccountId])
}

model Payment {
  id             String      @id @default(uuid())
  type           PaymentType
  invoiceId      String?
  billId         String?
  amount         Decimal     @db.Decimal(18, 2)
  date           DateTime
  method         String?
  journalEntryId String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  bill         Bill?         @relation(fields: [billId], references: [id], onDelete: SetNull)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([billId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Phase 6 — CRM & CPQ (Sales Quoting)
//
// Quotes hold customer-facing pricing with snapshot freeze on send. PRODUCT
// lines use rule-based pricing; FABRICATED lines use the FabQuote engine.
// CpqMaterial/CpqCatalogPart back the fabrication catalog; CpqSetting holds
// rate card, pricing config, and formula overrides.
// ---------------------------------------------------------------------------

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuoteLineKind {
  PRODUCT
  FABRICATED
}

model Quote {
  id              String      @id @default(uuid())
  quoteNumber     String      @unique
  customerId      String
  status          QuoteStatus @default(DRAFT)
  validUntil      DateTime?
  notes           String?
  currency        String      @default("USD")
  createdById     String?
  sentAt          DateTime?
  pricingSnapshot Json?
  subtotal        Decimal     @default(0) @db.Decimal(18, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(18, 2)
  total           Decimal     @default(0) @db.Decimal(18, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id])
  lines    QuoteLine[]
  salesOrder SalesOrder?

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model QuoteLine {
  id              String        @id @default(uuid())
  quoteId         String
  lineNumber      Int
  kind            QuoteLineKind
  productId       String?
  description     String
  quantity        Decimal       @default(1) @db.Decimal(18, 4)
  unitPrice       Decimal       @default(0) @db.Decimal(18, 4)
  discountPct     Decimal       @default(0) @db.Decimal(9, 4)
  manualUnitPrice Decimal?      @db.Decimal(18, 4)
  overrideReason  String?
  lineTotal       Decimal       @default(0) @db.Decimal(18, 2)
  fabInput        Json?
  costBreakdown   Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([quoteId, lineNumber])
  @@index([quoteId])
  @@index([productId])
}

model CpqMaterial {
  id              String   @id @default(uuid())
  itemNumber      String   @unique
  description     String
  standardCost    Decimal  @default(0) @db.Decimal(18, 4)
  uom             Decimal  @default(0) @db.Decimal(18, 4)
  uomProcess      Decimal  @default(0) @db.Decimal(18, 4)
  cutSpeedInMin   Decimal  @default(0) @db.Decimal(18, 4)
  pierceTimeSecs  Decimal  @default(0) @db.Decimal(18, 4)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
}

model CpqCatalogPart {
  id           String   @id @default(uuid())
  itemNumber   String   @unique
  description  String
  itemType     String?
  source       String
  standardCost Decimal  @default(0) @db.Decimal(18, 4)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([source])
}

model CpqSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Phase 7 — Sales Order Management & Fulfillment
//
// Sales orders convert from accepted quotes at frozen pricing. PRODUCT lines
// allocate from WMS inventory; FABRICATED lines are make-to-order (toProduce).
// Shipments trigger Finance invoicing for shipped quantity only.
// ---------------------------------------------------------------------------

enum SalesOrderStatus {
  DRAFT
  ALLOCATED
  BACKORDERED
  PARTIALLY_SHIPPED
  SHIPPED
  CANCELLED
}

enum SalesOrderLineKind {
  PRODUCT
  FABRICATED
}

model SalesOrder {
  id                String           @id @default(uuid())
  orderNumber       String           @unique
  quoteId           String?          @unique
  customerId        String
  status            SalesOrderStatus @default(DRAFT)
  requestedShipDate DateTime?
  currency          String           @default("USD")
  notes             String?
  createdById       String?
  subtotal          Decimal          @default(0) @db.Decimal(18, 2)
  total             Decimal          @default(0) @db.Decimal(18, 2)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customer  Customer             @relation(fields: [customerId], references: [id])
  quote     Quote?               @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  lines     SalesOrderLine[]
  shipments SalesOrderShipment[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model SalesOrderLine {
  id                String             @id @default(uuid())
  orderId           String
  lineNumber        Int
  kind              SalesOrderLineKind
  productId         String?
  description       String
  unitPrice         Decimal            @default(0) @db.Decimal(18, 4)
  qtyOrdered        Decimal            @default(0) @db.Decimal(18, 4)
  qtyAllocated      Decimal            @default(0) @db.Decimal(18, 4)
  qtyShipped        Decimal            @default(0) @db.Decimal(18, 4)
  qtyBackordered    Decimal            @default(0) @db.Decimal(18, 4)
  toProduce         Boolean            @default(false)
  lineTotal         Decimal            @default(0) @db.Decimal(18, 2)
  allocationDetails Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([orderId, lineNumber])
  @@index([orderId])
  @@index([productId])
}

model SalesOrderShipment {
  id             String   @id @default(uuid())
  orderId        String
  shipmentNumber String
  invoiceId      String?
  shippedAt      DateTime @default(now())
  lines          Json
  createdAt      DateTime @default(now())

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Phase 8 — MPS (Master Production Schedule)
//
// Aggregates sales demand into work orders using Weekly, Monthly, or
// Build-To-Order strategies. Factory calendar and production lines define
// capacity; overload is flagged rather than silently over-scheduled.
// ---------------------------------------------------------------------------

enum MpsStrategy {
  WEEKLY
  MONTHLY
  BUILD_TO_ORDER
}

enum WorkOrderStatus {
  PROPOSED
  FIRM
  IN_PROGRESS
  AWAITING_VERIFICATION
  VERIFIED
  COMPLETED
  CANCELLED
}

model ProductionLine {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  active         Boolean  @default(true)
  capacityPerDay Decimal  @default(0) @db.Decimal(18, 4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workOrders WorkOrder[]

  @@index([active])
}

model FactoryCalendarDay {
  id            String   @id @default(uuid())
  date          DateTime @unique @db.Date
  isWorkingDay  Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isWorkingDay])
}

model WorkOrder {
  id             String          @id @default(uuid())
  woNumber       String          @unique
  productId      String
  lineId         String?
  quantity       Decimal         @default(0) @db.Decimal(18, 4)
  scheduledStart DateTime
  scheduledEnd   DateTime
  status         WorkOrderStatus @default(PROPOSED)
  strategy       MpsStrategy
  periodKey      String
  demandRefs     Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  product Product         @relation(fields: [productId], references: [id])
  line    ProductionLine? @relation(fields: [lineId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]
  operations WorkOrderOperation[]
  verification WorkOrderVerification?

  @@index([status])
  @@index([productId])
  @@index([periodKey])
  @@index([scheduledStart])
}

model MpsSetting {
  id        String      @id @default(uuid())
  scope     String      @unique
  strategy  MpsStrategy
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ---------------------------------------------------------------------------
// Phase 9 — MRP (Material Requirements Planning)
//
// Multi-level BOM explosion from open work orders drives component net demand.
// BUY components generate purchase requisitions with need-by dates back-
// calculated from WO start and lead time. Requisitions are idempotent on
// (componentProductId, needByDate).
// ---------------------------------------------------------------------------

enum ProcurementType {
  MAKE
  BUY
}

enum RequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED
}

model BillOfMaterials {
  id        String    @id @default(uuid())
  productId String    @unique
  active    Boolean   @default(true)
  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  product Product   @relation(fields: [productId], references: [id])
  lines   BomLine[]

  @@index([active])
}

model BomLine {
  id                 String   @id @default(uuid())
  bomId              String
  componentProductId String
  quantityPer        Decimal  @default(1) @db.Decimal(18, 4)
  scrapFactor        Decimal  @default(0) @db.Decimal(18, 4)
  createdAt          DateTime @default(now())

  bom       BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  component Product         @relation("BomComponent", fields: [componentProductId], references: [id])

  @@index([bomId])
  @@index([componentProductId])
}

model PurchaseRequisition {
  id                 String            @id @default(uuid())
  reqNumber          String            @unique
  componentProductId String
  quantity           Decimal           @default(0) @db.Decimal(18, 4)
  needByDate         DateTime          @db.Date
  status             RequisitionStatus @default(PENDING)
  preferredVendorId  String?
  demandRefs         Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  component       Product @relation(fields: [componentProductId], references: [id])
  preferredVendor Vendor? @relation(fields: [preferredVendorId], references: [id], onDelete: SetNull)
  purchaseOrderLine PurchaseOrderLine?

  @@unique([componentProductId, needByDate])
  @@index([status])
  @@index([componentProductId])
}

// ---------------------------------------------------------------------------
// Phase 10 — Procurement & Vendor Integration
//
// Approved requisitions consolidate into purchase orders by vendor. Staff-on-
// behalf acknowledgment/ASN intake; receiveAgainstPo records PoReceipt and
// delegates on-hand increment to WMS.
// ---------------------------------------------------------------------------

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  ACKNOWLEDGED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum AsnStatus {
  SUBMITTED
  IN_TRANSIT
  ARRIVED
  CANCELLED
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  poNumber             String              @unique
  vendorId             String
  status               PurchaseOrderStatus @default(DRAFT)
  orderDate            DateTime            @default(now()) @db.Date
  expectedDeliveryDate DateTime?           @db.Date
  notes                String?
  demandRefs           Json?
  subtotal             Decimal             @default(0) @db.Decimal(18, 2)
  total                Decimal             @default(0) @db.Decimal(18, 2)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  vendor           Vendor                @relation(fields: [vendorId], references: [id])
  lines            PurchaseOrderLine[]
  acknowledgments  VendorAcknowledgment[]
  asns             AdvanceShipmentNotice[]

  @@index([status])
  @@index([vendorId])
}

model PurchaseOrderLine {
  id                   String   @id @default(uuid())
  poId                 String
  productId            String
  requisitionId        String?  @unique
  description          String
  quantity             Decimal  @default(0) @db.Decimal(18, 4)
  unitPrice            Decimal? @db.Decimal(18, 2)
  lineTotal            Decimal? @db.Decimal(18, 2)
  expectedDeliveryDate DateTime? @db.Date
  qtyReceived          Decimal  @default(0) @db.Decimal(18, 4)
  createdAt            DateTime @default(now())

  po          PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  product     Product              @relation(fields: [productId], references: [id])
  requisition PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  receipts    PoReceipt[]

  @@index([poId])
}

model PoReceipt {
  id         String   @id @default(uuid())
  poLineId   String
  quantity   Decimal  @default(0) @db.Decimal(18, 4)
  receivedAt DateTime @default(now())
  movementId String?
  createdAt  DateTime @default(now())

  poLine PurchaseOrderLine @relation(fields: [poLineId], references: [id], onDelete: Cascade)

  @@index([poLineId])
}

model VendorAcknowledgment {
  id                    String    @id @default(uuid())
  poId                  String
  confirmedDeliveryDate DateTime? @db.Date
  note                  String?
  acknowledgedAt        DateTime  @default(now())
  createdAt             DateTime  @default(now())

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}

model AdvanceShipmentNotice {
  id              String    @id @default(uuid())
  poId            String
  status          AsnStatus @default(SUBMITTED)
  shipDate        DateTime? @db.Date
  expectedArrival DateTime? @db.Date
  carrier         String?
  trackingNumber  String?
  createdAt       DateTime  @default(now())

  po    PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  lines AsnLine[]

  @@index([poId])
}

model AsnLine {
  id        String   @id @default(uuid())
  asnId     String
  productId String
  quantity  Decimal  @default(0) @db.Decimal(18, 4)
  createdAt DateTime @default(now())

  asn     AdvanceShipmentNotice @relation(fields: [asnId], references: [id], onDelete: Cascade)
  product Product               @relation(fields: [productId], references: [id])

  @@index([asnId])
}

// ---------------------------------------------------------------------------
// Phase 11 — Workforce Management (Time & Scheduling)
//
// Employees (optional User link), shift assignments aligned to the factory
// calendar, time entries with clock-in/out validation, and unavailability
// for scheduling conflict prevention.
// ---------------------------------------------------------------------------

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum TimeEntryStatus {
  OPEN
  CLOSED
  FLAGGED
}

model Employee {
  id             String            @id @default(uuid())
  employeeNumber String            @unique
  firstName      String
  lastName       String
  department     String?
  badgeCode      String?           @unique
  laborRate      Decimal           @default(0) @db.Decimal(18, 2)
  status         EmploymentStatus  @default(ACTIVE)
  userId         String?           @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user             User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignments      ShiftAssignment[]
  timeEntries      TimeEntry[]
  unavailability   EmployeeUnavailability[]
  cycleRecords     CycleRecord[]

  @@index([status])
  @@index([department])
}

model Shift {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  startTime  String
  endTime    String
  daysOfWeek Int[]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assignments ShiftAssignment[]

  @@index([active])
}

model ShiftAssignment {
  id         String   @id @default(uuid())
  shiftId    String
  employeeId String
  date       DateTime @db.Date
  createdAt  DateTime @default(now())

  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date, shiftId])
  @@index([date])
  @@index([shiftId])
}

model TimeEntry {
  id              String          @id @default(uuid())
  employeeId      String
  clockIn         DateTime
  clockOut        DateTime?
  durationMinutes Int?
  workOrderId     String?
  department      String?
  status          TimeEntryStatus @default(OPEN)
  flagReason      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([status])
  @@index([workOrderId])
}

model EmployeeUnavailability {
  id         String   @id @default(uuid())
  employeeId String
  fromDate   DateTime @db.Date
  toDate     DateTime @db.Date
  reason     String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ---------------------------------------------------------------------------
// Phase 12 — MES (Production Execution)
//
// Workstations, sequential work-order operations, cycle records attributed
// to clocked-in operators, and supervisor verification with photo evidence.
// ---------------------------------------------------------------------------

enum WorkstationStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum OperationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Workstation {
  id          String            @id @default(uuid())
  code        String            @unique
  name        String
  description String?
  status      WorkstationStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  operations WorkOrderOperation[]

  @@index([status])
}

model WorkOrderOperation {
  id              String          @id @default(uuid())
  workOrderId     String
  workstationId   String?
  sequence        Int
  name            String
  status          OperationStatus @default(PENDING)
  standardMinutes Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workOrder   WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workstation Workstation? @relation(fields: [workstationId], references: [id], onDelete: SetNull)
  cycles      CycleRecord[]

  @@unique([workOrderId, sequence])
  @@index([workOrderId])
  @@index([workstationId])
  @@index([status])
}

model CycleRecord {
  id                String    @id @default(uuid())
  operationId       String
  employeeId        String
  startedAt         DateTime
  endedAt           DateTime?
  durationMinutes   Int?
  quantityCompleted Decimal   @default(0) @db.Decimal(18, 4)
  quantityScrapped  Decimal   @default(0) @db.Decimal(18, 4)
  createdAt         DateTime  @default(now())

  operation WorkOrderOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  employee  Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([operationId])
  @@index([employeeId])
}

model WorkOrderVerification {
  id                  String   @id @default(uuid())
  workOrderId         String   @unique
  verifiedByUserId    String
  verifiedByEmployeeId String?
  notes               String?
  photoObjectKey      String?
  photoFileName       String?
  verifiedAt          DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([verifiedByUserId])
}

// ---------------------------------------------------------------------------
// Phase 2 — Data Migration & Legacy Cutover (staging area)
//
// Legacy records land in staging tables first so an operator can review counts
// and conflicts before promoting into the production Master Data tables above.
// Legacy quotes may still land in StagingQuote during cutover; production quotes
// use the Quote model above (Phase 6).
// ---------------------------------------------------------------------------

enum MigrationBatchStatus {
  EXTRACTED
  LOADED
  RECONCILED
  PROMOTED
  ROLLED_BACK
  FAILED
}

enum StagingRecordStatus {
  PENDING
  VALID
  CONFLICT
  PROMOTED
  SKIPPED
}

enum MigrationEntityType {
  CUSTOMER
  VENDOR
  PRODUCT
  QUOTE
}

model MigrationBatch {
  id           String               @id @default(uuid())
  sourceSystem String
  status       MigrationBatchStatus @default(EXTRACTED)
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  customers StagingCustomer[]
  vendors   StagingVendor[]
  products  StagingProduct[]
  quotes    StagingQuote[]

  @@index([status])
}

model StagingCustomer {
  id             String              @id @default(uuid())
  batchId        String
  sourceSystem   String
  sourceId       String
  status         StagingRecordStatus @default(PENDING)
  conflictReason String?
  promotedId     String?
  raw            Json
  name           String?
  email          String?
  phone          String?
  billingAddress Json?
  shippingAddress Json?
  creditTerms    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  batch MigrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([sourceSystem, sourceId])
  @@index([batchId])
  @@index([status])
}

model StagingVendor {
  id             String              @id @default(uuid())
  batchId        String
  sourceSystem   String
  sourceId       String
  status         StagingRecordStatus @default(PENDING)
  conflictReason String?
  promotedId     String?
  raw            Json
  name           String?
  email          String?
  phone          String?
  address        Json?
  paymentTerms   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  batch MigrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([sourceSystem, sourceId])
  @@index([batchId])
  @@index([status])
}

model StagingProduct {
  id              String              @id @default(uuid())
  batchId         String
  sourceSystem    String
  sourceId        String
  status          StagingRecordStatus @default(PENDING)
  conflictReason  String?
  promotedId      String?
  raw             Json
  sku             String?
  description     String?
  unitOfMeasure   String?
  category        String?
  inventoryOnHand Float?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  batch MigrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([sourceSystem, sourceId])
  @@index([batchId])
  @@index([status])
}

model StagingQuote {
  id             String              @id @default(uuid())
  batchId        String
  sourceSystem   String
  sourceId       String
  status         StagingRecordStatus @default(PENDING)
  conflictReason String?
  promotedId     String?
  raw            Json
  customerSourceId String?
  quoteNumber    String?
  status_legacy  String?
  totalAmount    Float?
  currency       String?
  quotedAt       DateTime?
  lineItems      Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  batch MigrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([sourceSystem, sourceId])
  @@index([batchId])
  @@index([status])
}
