# Demo environment — copy to .env.demo for local compose overrides
SEED_PROFILE=demo
SKIP_DEMO_SEED=false

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://anc:anc@postgres:5432/anc_suite?schema=public
REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anc-suite
MINIO_USE_SSL=false

JWT_ACCESS_SECRET=demo-access-secret-change-in-production
JWT_REFRESH_SECRET=demo-refresh-secret-change-in-production

# GHCR images (when not building locally)
# ghcr.io/icors2/businesssuite-api:demo
# ghcr.io/icors2/businesssuite-web:demo
