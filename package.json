{
  "name": "anc-business-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Arc N Code Business Suite — manufacturing operations platform",
  "scripts": {
    "build": "nx build api",
    "serve": "nx serve api",
    "test": "nx run-many -t test --projects=config,database,event-bus,audit,health,auth,api",
    "lint": "nx run-many -t lint --all",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "prisma:generate": "prisma generate --schema=libs/shared/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=libs/shared/database/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=libs/shared/database/prisma/schema.prisma",
    "prisma:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} libs/shared/database/prisma/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} libs/shared/database/prisma/seed.ts"
  },
  "keywords": [],
  "author": "Arc N Code",
  "license": "UNLICENSED",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "^23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/jest": "^23.0.0",
    "@nx/js": "^23.0.0",
    "@nx/nest": "^23.0.0",
    "@nx/node": "^23.0.0",
    "@nx/web": "23.0.0",
    "@nx/webpack": "^23.0.0",
    "@swc/helpers": "~0.5.18",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-util": "^29.7.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.0",
    "prettier": "^3.8.4",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.40.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.1"
  },
  "nx": {},
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/client": "^6.19.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
