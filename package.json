{
  "name": "anc-business-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Arc N Code Business Suite — manufacturing operations platform",
  "scripts": {
    "build": "nx build api",
    "build:web": "nx build web",
    "serve": "nx serve api",
    "serve:web": "nx serve web",
    "test": "nx run-many -t test --projects=config,database,event-bus,audit,health,auth,masterdata,migration,finance,plm,wms,cpq,sales,mps,api",
    "lint": "nx run-many -t lint --all",
    "migrate:run": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate.ts run",
    "migrate:ingest": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate.ts ingest",
    "migrate:reconcile": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate.ts reconcile",
    "migrate:promote": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate.ts promote",
    "migrate:rollback": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate.ts rollback",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "prisma:generate": "prisma generate --schema=libs/shared/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=libs/shared/database/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=libs/shared/database/prisma/schema.prisma",
    "prisma:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} libs/shared/database/prisma/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} libs/shared/database/prisma/seed.ts"
  },
  "keywords": [],
  "author": "Arc N Code",
  "license": "UNLICENSED",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "^23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/jest": "^23.0.0",
    "@nx/js": "^23.0.0",
    "@nx/nest": "^23.0.0",
    "@nx/node": "^23.0.0",
    "@nx/react": "^23.0.0",
    "@nx/vite": "^23.0.0",
    "@nx/web": "23.0.0",
    "@nx/webpack": "^23.0.0",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
