    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.16",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.1"
  },
  "nx": {},
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
